aws_region   = "us-east-2"
project_name = "absencesbo"
environment  = "experimental"

# Prefer SSM Session Manager for dev access.
# Enable SSH only if you really need it.
require_ssh_key_pair = false
create_ssh_key_pair  = false
key_pair_name        = ""

# Keep administrative access closed by default.
allowed_ssh_cidrs = []
allowed_k3s_cidrs = []

# Public web access for the dev application.
allowed_web_cidrs = ["0.0.0.0/0"]

# Direct NodePort access should be closed by default.
# The NLB targets app_nodeport internally; external users should normally use HTTP/HTTPS.
allowed_nodeport_cidrs = []

# Network sizing.
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# EC2 sizing.
instance_type     = "t3.small"
root_volume_type  = "gp3"
root_volume_size  = 30
data_volume_type  = "gp3"
data_volume_size  = 20
data_device_name  = "/dev/sdf"

# k3s service NodePort targeted by the NLB.
app_nodeport = 32322

tags = {
  Owner = "dev"
}
